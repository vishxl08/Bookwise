# Copy this file to .env and fill in your values:
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env (Windows)

# Local dev uses SQLite. In production on Vercel, leave this unset and instead
# link a Storage > Postgres database to the project — Vercel injects POSTGRES_URL
# automatically and backend/config.py picks it up in place of this default.
DATABASE_URL=sqlite:///./bookwise.db
GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=any_random_string_for_jwt_signing
GOOGLE_BOOKS_API_KEY=
